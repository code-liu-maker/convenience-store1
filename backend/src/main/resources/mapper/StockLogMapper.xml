<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.lhs.mapper.StockLogMapper">

    <resultMap id="BaseResultMap" type="com.lhs.model.StockLog">
        <id column="log_id" property="logId"/>
        <result column="product_id" property="productId"/>
        <result column="product_name" property="productName"/>
        <result column="operation_type" property="operationType"/>
        <result column="quantity" property="quantity"/>
        <result column="operator" property="operator"/>
        <result column="remark" property="remark"/>
        <result column="operation_time" property="operationTime"/>
    </resultMap>

    <insert id="insert" useGeneratedKeys="true" keyProperty="logId">
        insert into tb_stock_log(product_id, product_name, operation_type, quantity, operator, remark, operation_time)
        values(#{productId}, #{productName}, #{operationType}, #{quantity}, #{operator}, #{remark}, #{operationTime})
    </insert>

    <select id="findByProductId" resultMap="BaseResultMap">
        select * from tb_stock_log where product_id = #{productId} order by operation_time desc
    </select>

    <select id="findPage" resultMap="BaseResultMap">
        select * from tb_stock_log order by operation_time desc limit #{offset}, #{pageSize}
    </select>

    <select id="countTotal" resultType="int">
        select count(*) from tb_stock_log
    </select>
</mapper>