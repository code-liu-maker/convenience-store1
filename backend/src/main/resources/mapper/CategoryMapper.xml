<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.lhs.mapper.CategoryMapper">

    <resultMap id="BaseResultMap" type="com.lhs.model.Category">
        <id column="category_id" property="categoryId"/>
        <result column="category_name" property="categoryName"/>
        <result column="sort_order" property="sortOrder"/>
        <result column="status" property="status"/>
        <result column="create_time" property="createTime"/>
    </resultMap>

    <select id="findAll" resultMap="BaseResultMap">
        select * from tb_category order by sort_order asc
    </select>

    <select id="findEnabled" resultMap="BaseResultMap">
        select * from tb_category where status = 0 order by sort_order asc
    </select>

    <select id="findById" resultMap="BaseResultMap">
        select * from tb_category where category_id = #{categoryId}
    </select>

    <insert id="insert" useGeneratedKeys="true" keyProperty="categoryId">
        insert into tb_category(category_name, sort_order, status, create_time)
        values(#{categoryName}, #{sortOrder}, #{status}, now())
    </insert>

    <update id="update">
        update tb_category
        set category_name = #{categoryName}, sort_order = #{sortOrder}, status = #{status}
        where category_id = #{categoryId}
    </update>

    <delete id="deleteById">
        delete from tb_category where category_id = #{categoryId}
    </delete>
</mapper>