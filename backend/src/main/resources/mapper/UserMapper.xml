<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.lhs.mapper.UserMapper">

    <resultMap id="BaseResultMap" type="com.lhs.model.User">
        <id column="user_id" property="userId"/>
        <result column="login_id" property="loginId"/>
        <result column="password" property="password"/>
        <result column="user_name" property="userName"/>
        <result column="mobile" property="mobile"/>
        <result column="email" property="email"/>
        <result column="user_type" property="userType"/>
        <result column="status" property="status"/>
        <result column="create_time" property="createTime"/>
    </resultMap>

    <select id="findAll" resultMap="BaseResultMap">
        select * from tb_user order by create_time desc
    </select>

    <select id="findById" resultMap="BaseResultMap">
        select * from tb_user where user_id = #{userId}
    </select>

    <select id="findByLoginId" resultMap="BaseResultMap">
        select * from tb_user where login_id = #{loginId}
    </select>

    <insert id="insert" useGeneratedKeys="true" keyProperty="userId">
        insert into tb_user(login_id, password, user_name, mobile, email, user_type, status, create_time)
        values(#{loginId}, #{password}, #{userName}, #{mobile}, #{email}, #{userType}, #{status}, now())
    </insert>

    <update id="update">
        update tb_user
        set user_name = #{userName}, mobile = #{mobile}, email = #{email},
            user_type = #{userType}, status = #{status}
        where user_id = #{userId}
    </update>

    <delete id="deleteById">
        delete from tb_user where user_id = #{userId}
    </delete>

    <select id="findPage" resultMap="BaseResultMap">
        select * from tb_user order by create_time desc limit #{offset}, #{pageSize}
    </select>

    <select id="countTotal" resultType="int">
        select count(*) from tb_user
    </select>
</mapper>